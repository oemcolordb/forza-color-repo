{
  "name": "forza-color-repo",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "electron": "electron electron/main.js",
    "electron:build": "npm run build && electron-builder",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "dist": "npm run build && tauri build"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "critters": "^0.0.23",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.13.3",
    "@tauri-apps/cli": "^2.8.4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.20",
    "electron": "^38.2.0",
    "electron-builder": "^26.0.12",
    "electron-packager": "^17.1.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "netlify-plugin-cache": "^1.0.3",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  },
  "build": {
    "appId": "com.forzacolors.app",
    "productName": "Forza Color Universe",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "services/**/*",
      "public/icon.svg",
      "!node_modules/@img/sharp-darwin-*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
