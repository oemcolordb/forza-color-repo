# Gemini AI API Key for enhanced color descriptions and recommendations
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Application Configuration
NEXT_PUBLIC_APP_NAME="Forza Color Universe"
NEXT_PUBLIC_APP_DESCRIPTION="Explore 10,000+ official automotive colors from Forza racing games"
NEXT_PUBLIC_APP_URL="https://forza-colors.netlify.app"

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Performance Settings
NEXT_TELEMETRY_DISABLED=1

# Development Settings
NODE_ENV=development