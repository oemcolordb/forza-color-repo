// Test script to verify authentication functionality
const bcrypt = require('bcryptjs')
const jwt = require('jsonwebtoken')
const { v4: uuidv4 } = require('uuid')

console.log('Testing authentication system...\n')

// Test 1: Password hashing
console.log('1. Testing password hashing...')
const testPassword = 'testpassword123'
const hashedPassword = bcrypt.hashSync(testPassword, 12)
const isValid = bcrypt.compareSync(testPassword, hashedPassword)
console.log(`✅ Password hashing: ${isValid ? 'PASS' : 'FAIL'}`)

// Test 2: JWT token generation
console.log('\n2. Testing JWT token generation...')
const JWT_SECRET = 'test-secret'
const testUser = {
  id: uuidv4(),
  email: 'test@example.com',
  name: 'Test User',
  role: 'user'
}

const token = jwt.sign({
  sub: testUser.id,
  email: testUser.email,
  name: testUser.name,
  role: testUser.role,
  exp: Math.floor(Date.now() / 1000) + (7 * 24 * 60 * 60)
}, JWT_SECRET)

try {
  const decoded = jwt.verify(token, JWT_SECRET)
  console.log(`✅ JWT generation: PASS`)
  console.log(`   Token payload: ${JSON.stringify(decoded, null, 2)}`)
} catch (error) {
  console.log(`❌ JWT generation: FAIL - ${error.message}`)
}

// Test 3: File system operations (simulate Netlify function storage)
console.log('\n3. Testing file system operations...')
const fs = require('fs')
const path = require('path')

const testFile = path.join(__dirname, 'test-users.json')
const testUsers = {
  'test@example.com': {
    id: testUser.id,
    email: testUser.email,
    name: testUser.name,
    passwordHash: hashedPassword,
    role: testUser.role,
    createdAt: new Date().toISOString()
  }
}

try {
  fs.writeFileSync(testFile, JSON.stringify(testUsers, null, 2))
  const loadedUsers = JSON.parse(fs.readFileSync(testFile, 'utf8'))
  const userExists = loadedUsers['test@example.com'] !== undefined
  
  // Cleanup
  fs.unlinkSync(testFile)
  
  console.log(`✅ File operations: ${userExists ? 'PASS' : 'FAIL'}`)
} catch (error) {
  console.log(`❌ File operations: FAIL - ${error.message}`)
}

console.log('\n🎉 Authentication system test completed!')
console.log('\nNext steps:')
console.log('1. Set JWT_SECRET environment variable in Netlify')
console.log('2. Test signup/login through the web interface')
console.log('3. Check Netlify function logs for any issues')